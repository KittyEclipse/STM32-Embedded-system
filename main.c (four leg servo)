/**
  ******************************************************************************
  * @file           : main.c
  * @brief          : STM32F407 + PCA9685 (I2C3) leg walk, gated by UART2 confirm from Jetson
  *
  * UART2 protocol (ASCII lines):
  *   - STM32 prints: "STM32 READY. Send GO"
  *   - Jetson sends: "GO\n"  -> STM32 starts walking
  *   - Jetson sends: "STOP\n" -> STM32 disables outputs and waits for GO again
  *
  * PCA9685 channel map (your wiring):
  *   Front Right: CH0 hip, CH2 knee, CH1 extension
  *   Front Left:  CH3 hip, CH5 knee, CH4 extension
  *   Back Right:  CH6 hip, CH7 knee
  *   Back Left:   CH8 hip, CH9 knee (kept FULL OFF in this file unless you enable it)
  ******************************************************************************
  */
/* USER CODE END Header */

/* Includes ------------------------------------------------------------------*/
#include "main.h"
#include "pca9685.h"
#include <stdio.h>
#include <stdarg.h>
#include <string.h>
#include <ctype.h>

/* Private define ------------------------------------------------------------*/

// ===== PCA9685 I2C address (A0..A5 all low) =====
#define PCA9685_ADDR_7BIT          0x40

// ===== PCA9685 channel mapping (your wiring) =====
// Front Right (existing leg)
#define FR_HIP_CH                 0
#define FR_KNEE_CH                2
#define FR_EXT_CH                 1

// Front Left (identical to front right)
#define FL_HIP_CH                 3
#define FL_KNEE_CH                5
#define FL_EXT_CH                 4

// Back Right (hip + knee only)
#define BR_HIP_CH                 6
#define BR_KNEE_CH                7

// Back Left (hip + knee only)
#define BL_HIP_CH                 8
#define BL_KNEE_CH                9

// ===== Servo pulse ranges (tune per servo) =====
#define HIP_MIN_US                 900.0f
#define HIP_MAX_US                 2200.0f
#define KNEE_MIN_US                900.0f
#define KNEE_MAX_US                2200.0f
#define EXT_MIN_US                 950.0f
#define EXT_MAX_US                 2050.0f

// ===== Neutral pose (degrees) =====
// Front legs
#define FR_HIP_NEUTRAL_DEG        100.0f
#define FR_KNEE_NEUTRAL_DEG         0.0f
#define FR_EXT_NEUTRAL_DEG         55.0f

#define FL_HIP_NEUTRAL_DEG        100.0f
#define FL_KNEE_NEUTRAL_DEG         0.0f
#define FL_EXT_NEUTRAL_DEG         55.0f

// Back legs (hip+knee only) — start with same neutrals, tweak later if needed
#define BR_HIP_NEUTRAL_DEG        100.0f
#define BR_KNEE_NEUTRAL_DEG         0.0f

#define BL_HIP_NEUTRAL_DEG        100.0f
#define BL_KNEE_NEUTRAL_DEG         0.0f

// ===== Invert directions if needed (0=no invert, 1=invert) =====
#define INV_HIP                    0
#define INV_KNEE                   0
#define INV_EXT                    0

// ===== Walking timing =====
#define CONTROL_DT_MS              15U
#define STEP_PERIOD_MS             1100U
#define START_HOLD_MS              1200U
#define GAIT_RAMP_MS               1500U

// ===== Gait amplitudes =====
#define HIP_SWING_AMPL_DEG         36.0f
#define KNEE_BEND_AMPL_DEG         85.0f
#define EXT_LIFT_AMPL_DEG           0.0f

// ===== UART tokens =====
#define TOKEN_GO                   "GO"
#define TOKEN_STOP                 "STOP"
#define TOKEN_FWD                  "FWD"
#define TOKEN_BACK                 "BACK"

// ===== UART receive timeouts =====
#define UART_BYTE_TIMEOUT_MS       10U
#define UART_LINE_MAX              32

/* Private variables ---------------------------------------------------------*/
I2C_HandleTypeDef hi2c3;
UART_HandleTypeDef huart2;

PCA9685_Handle_t pca;

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_I2C3_Init(void);
